# LLM Council API - Environment Configuration
# See also: ../llm-council-frontend/.env.example for frontend config

# ==========================================
# API Keys (REQUIRED)
# ==========================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Get your key from: https://console.anthropic.com/settings/keys
# Used for: Claude Sonnet 4.6 (Head), Claude Haiku 4.5 (Member)

GROQ_API_KEY=your_groq_api_key_here
# Get your key from: https://console.groq.com/keys
# Used for: GPT OSS 120B, GPT OSS 20B, Qwen 3 32B

# ==========================================
# Database (REQUIRED)
# ==========================================
MONGODB_URL=mongodb://localhost:27017
MONGODB_DATABASE=llm_council

# ==========================================
# Security
# ==========================================
API_KEY=your_secret_api_key_here
# Leave empty to disable API authentication (not recommended for production)

# ==========================================
# CORS Configuration
# ==========================================
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Comma-separated list of allowed origins

# ==========================================
# Environment
# ==========================================
ENVIRONMENT=production
# Set to "production" to disable OpenAPI docs

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_REQUESTS=100
# Number of requests allowed per window
RATE_LIMIT_WINDOW=60
# Window duration in seconds (default: 60 = 1 minute)

# ==========================================
# Circuit Breaker
# ==========================================
CIRCUIT_BREAKER_FAIL_MAX=5
# Number of failures before opening circuit
CIRCUIT_BREAKER_TIMEOUT=60
# Seconds to wait before trying again after circuit opens
